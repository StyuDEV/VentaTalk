{
  "name": "ventatalk",
  "version": "1.1.0",
  "description": "VentaTalk — dictée vocale système locale (clone de Wispr Flow) : whisper.cpp + LLM local, 100% hors-ligne.",
  "main": "./out/main/index.js",
  "author": "VentaTalk",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "rebuild": "electron-builder install-app-deps",
    "dist": "electron-vite build && electron-builder",
    "dist:dir": "electron-vite build && electron-builder --dir",
    "release": "electron-vite build && electron-builder --publish always"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "node-llama-cpp": "^3.18.0",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "typescript": "^5.6.0"
  }
}
